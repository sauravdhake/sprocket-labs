{
  "name": "economy-service",
  "version": "1.0.0",
  "private": true,
  "description": "Durable wallet/economy backend service (credit, purchase, one-time reward claim) with exactly-once and crash-safe guarantees.",
  "type": "module",
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node --experimental-sqlite dist/index.js",
    "dev": "tsx watch --experimental-sqlite src/index.ts",
    "test": "tsx --experimental-sqlite --test tests/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^4.21.2",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.13.14",
    "@types/swagger-ui-express": "^4.1.8",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
